{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-stations",
      "schedule": "0 3 * * 0"
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ]
}
