{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "memory": 128,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-stations",
      "schedule": "0 3 * * 0"
    },
    {
      "path": "/api/cron/sync-cameras?country=BG",
      "schedule": "0 4 * * 0"
    },
    {
      "path": "/api/cron/sync-cameras?country=NO-S1",
      "schedule": "10 4 * * 0"
    },
    {
      "path": "/api/cron/sync-cameras?country=NO-S2",
      "schedule": "20 4 * * 0"
    },
    {
      "path": "/api/cron/sync-cameras?country=NO-M",
      "schedule": "30 4 * * 0"
    },
    {
      "path": "/api/cron/sync-cameras?country=NO-N",
      "schedule": "40 4 * * 0"
    }
  ],
  "rewrites": [
    { "source": "/admin", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "DENY" },
        { "key": "Referrer-Policy",              "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",           "value": "camera=(), microphone=(), payment=()" },
        { "key": "Strict-Transport-Security",    "value": "max-age=31536000; includeSubDomains" },
        { "key": "Content-Security-Policy",      "value": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; font-src 'self' data:; worker-src blob:;" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
