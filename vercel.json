{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "memory": 256,
      "maxDuration": 15
    },
    "api/cron/*.ts": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync-stations",
      "schedule": "0 3 * * 0"
    }
  ]
}
