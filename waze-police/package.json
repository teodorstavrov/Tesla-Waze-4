{
  "name": "waze-police",
  "version": "1.0.0",
  "description": "Waze police marker ingestion microservice for Tesradar",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "discover": "tsx src/ingestion/browser/waze-playwright.client.ts",
    "ingest": "tsx src/ingestion/run-once.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "bullmq": "^5.4.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "ioredis": "^5.3.0",
    "pg": "^8.11.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "playwright": "^1.44.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
