# ─────────────────────────────────────────────
#  Waze Police Ingestion Microservice — Config
# ─────────────────────────────────────────────

# PostgreSQL / PostGIS
DATABASE_URL=postgresql://waze:waze_secret@localhost:5432/waze_police

# Redis (BullMQ + session cache)
REDIS_URL=redis://localhost:6379

# HTTP server
PORT=3001
NODE_ENV=production

# Waze API
WAZE_PRIMARY_URL=https://www.waze.com/live-map/api/georss
WAZE_FALLBACK_URL=https://www.waze.com/row-georss.ashx
WAZE_REQUEST_TIMEOUT_MS=15000
WAZE_MAX_RETRIES=3

# Bulgaria bounding box (lat/lng)
BG_BBOX_MIN_LAT=41.235
BG_BBOX_MAX_LAT=44.215
BG_BBOX_MIN_LNG=22.360
BG_BBOX_MAX_LNG=28.609

# Tiling: split BG into NxN grid (default 2 → 4 tiles)
BG_TILE_GRID=2

# Marker lifecycle
MARKER_TTL_MINUTES=90
EXPIRATION_INTERVAL_MS=900000

# BullMQ schedule intervals
INGEST_INTERVAL_MS=7200000
EXPIRE_INTERVAL_MS=900000

# Session cache TTL (seconds)
SESSION_TTL_SECONDS=14400

# Playwright browser (headless by default)
PLAYWRIGHT_HEADLESS=true

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# API auth (optional bearer token for write endpoints)
API_SECRET=change_me_in_production
